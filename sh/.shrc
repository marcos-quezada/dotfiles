# .shrc — /bin/sh interactive config (FreeBSD)
# loaded on each interactive shell via ENV=$HOME/.shrc in .profile

# ── editline key bindings ─────────────────────────────────────────────────────
# history search on up/down arrows (csh-style behaviour)
bind ^[[A ed-search-prev-history
bind ^[[B ed-search-next-history

# ctrl+right / ctrl+left: word-by-word navigation
bind "\\e[1;5C" em-next-word
bind "\\e[1;5D" ed-prev-word

# home/end keys (fixes MobaXterm and some VT keymaps)
bind ^[[5~ ed-move-to-beg
bind ^[[6~ ed-move-to-end

# ── prompt ────────────────────────────────────────────────────────────────────
PS1="
\033[32mℵ₀ \t\033[0m \w
λ❯ "

# ── aliases ───────────────────────────────────────────────────────────────────
alias h='fc -l'
alias history='fc -l'
alias j=jobs
alias m="$PAGER"
alias ll='ls -laFo'
alias l='ls -l'
alias g='grep -Ei'

# git
alias gs='git status'
alias gc='git commit'
alias gp='git pull --rebase'
alias gcam='git commit -am'
alias gl='git log --graph --pretty=format:"%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset" --abbrev-commit'

# clue — show the CLI cheatsheet; falls back to cat if bat is not installed
if command -v bat >/dev/null 2>&1; then
    alias clue='bat --style=plain --language=md ~/.config/cheatsheets/cli.md'
else
    alias clue='cat ~/.config/cheatsheets/cli.md'
fi

# handbook — open the locally installed FreeBSD handbook in w3m
alias handbook='w3m /usr/local/share/doc/freebsd/en/books/handbook/index.html'

# ── functions ─────────────────────────────────────────────────────────────────

# sync a branch with upstream and push to origin
gsync() {
    if [ -z "$1" ]; then
        echo "usage: gsync <branch>"
        return 1
    fi
    git branch --list "$1" | grep -q . || { echo "branch $1 does not exist"; return 1; }
    git checkout "$1" && git pull upstream "$1" && git push origin "$1"
}

# remove a line from ~/.ssh/known_hosts by line number
knownrm() {
    case "$1" in
        ''|*[!0-9]*) echo "error: line number required" >&2; return 1 ;;
    esac
    sed -i '' "${1}d" ~/.ssh/known_hosts
}
