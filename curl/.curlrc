# .curlrc — default curl options
# curl reads this file automatically; no sourcing needed.

# show errors even in silent mode, but suppress progress meter
--silent
--show-error

# follow redirects (3xx)
--location

# fail on HTTP errors (4xx, 5xx) rather than writing the error body
--fail

# abort if the transfer stalls for more than 30 seconds
--max-time 30
