# secrets — never commit real tokens or keys
# the template (config.env.template) is safe to commit; the live file is not
config.env

# ssh — the template is committed; the live config has real hostnames and key paths
ssh/.ssh/config

# macos
.DS_Store
.AppleDouble
.LSOverride

# editor state
.idea/
.vscode/
*.swp
*.swo
*~
.#*
\#*\#

# stow internals
.stow-local-ignore

# compiled / generated
*.pyc
__pycache__/

# nvim — plugin lockfile is machine-specific; let each machine regenerate it
nvim/.config/nvim/lazy-lock.json

# qmlls — Quickshell auto-populates this with machine-specific /var/run VFS paths on first run.
# stow creates the empty placeholder; each machine gets its own content.
quickshell/.config/quickshell/.qmlls.ini

# zsh — history and completion cache are runtime state
zsh/.zsh_history
zsh/.zcompdump*

# staging — local drop zone for system info files; never committed
staging/
